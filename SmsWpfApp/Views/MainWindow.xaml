<Window x:Class="SmsWpfApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SmsWpfApp.Converters"
        Title="Управление переменными среды" 
        Height="550" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Переменные среды пользователя" 
                   FontSize="18" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,15"/>

        <ListView Grid.Row="1" 
                  ItemsSource="{Binding Variables}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  BorderThickness="1"
                  BorderBrush="#DDDDDD"
                  Margin="0,0,0,15">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Поле" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" 
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="5,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Значение" Width="700">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="30"
                                         MaxHeight="100"
                                         HorizontalAlignment="Stretch"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="2"
                                         Padding="5"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Комментарий" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Exists, Converter={StaticResource BoolToStatusConverter}}"
                                           Foreground="{Binding Exists, Converter={StaticResource BoolToColorConverter}}"
                                           VerticalAlignment="Center"
                                           Margin="5,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">

            <Button Content="Сохранить все" 
                    Command="{Binding SaveAllCommand}"
                    Padding="15,8"
                    Margin="5"
                    FontSize="14"
                    Cursor="Hand"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"/>

            <Button Content="Сбросить к умолчанию" 
                    Command="{Binding RestoreDefaultsCommand}"
                    Padding="15,8"
                    Margin="5"
                    FontSize="14"
                    Cursor="Hand"
                    Background="#f44336"
                    Foreground="White"
                    BorderThickness="0"/>

            <Button Content="Обновить" 
                    Command="{Binding RefreshCommand}"
                    Padding="15,8"
                    Margin="5"
                    FontSize="14"
                    Cursor="Hand"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>

        <!-- Информационная панель -->
        <Border Grid.Row="2" 
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#F5F5F5"
                Padding="10"
                CornerRadius="5"
                Margin="0,0,20,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#666666"/>
        </Border>
    </Grid>
</Window>