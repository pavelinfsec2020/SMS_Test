<Window x:Class="SmsWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmsWpfApp"
        mc:Ignorable="d"
        Title="Управление переменными среды" 
        Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Переменные среды пользователя" 
                   FontSize="18" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,15"/>

        <!-- Список переменных -->
        <ListView Grid.Row="1" 
                  ItemsSource="{Binding Variables}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  BorderThickness="1"
                  BorderBrush="#DDDDDD"
                  Margin="0,0,0,15">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Поле" Width="250">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" 
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="5,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Значение" Width="450">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="30"
                                         MaxHeight="100"
                                         MinWidth="400"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="2"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Комментарий" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Exists, Converter={StaticResource BoolToStatusConverter}}"
                                           Foreground="{Binding Exists, Converter={StaticResource BoolToColorConverter}}"
                                           VerticalAlignment="Center"
                                           Margin="5,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">

            <Button Content="Сохранить все" 
                    Padding="15,8"
                    Margin="5"
                    FontSize="14"
                    Cursor="Hand"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Click="SaveAllButton_Click"/>

            <Button Content="Сбросить по дефолту" 
                    Padding="15,8"
                    Margin="5"
                    FontSize="14"
                    Cursor="Hand"
                    Background="#f44336"
                    Foreground="White"
                    BorderThickness="0"
                    Click="RestoreDefaultsButton_Click"/>

            <Button Content="Обновить" 
                    Padding="15,8"
                    Margin="5"
                    FontSize="14"
                    Cursor="Hand"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    Click="RefreshButton_Click"/>
        </StackPanel>

        <!-- Информационная панель -->
        <Border Grid.Row="2" 
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#F5F5F5"
                Padding="10"
                CornerRadius="5"
                Margin="0,0,20,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#666666"/>
        </Border>
    </Grid>
</Window>